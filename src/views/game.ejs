<html>
  <head>
    <title><%= game.title %></title>
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="stylesheet" href="/styles.css" />
  </head>
  <body>
    <%- include('components/header.ejs') %>
    <main>
      <div class="game-detail">
        <div class="game-cover">
          <% if (game.cover_image) { %>
          <img src="/image/<%= game.id %>" alt="<%= game.title %>" />
          <% } %>
        </div>
        <div class="game-info">
          <h1 class="game-title"><%= game.title %></h1>
          <p class="game-developer"><%= game.developer %></p>
          <div class="game-genres">
            <% game.genres.forEach(genre => { %>
            <span class="genre-tag"><%= genre %></span>
            <% }) %>
          </div>
          <div class="game-purchase">
            <span class="game-price">$<%= game.price %></span>
            <button class="card-btn" id="openUpdateDialog">Update</button>
            <button class="delete-btn" id="openGameDeleteDialog" data-id="<%= game.id %>">Delete</button>
          </div>
          <p class="game-stock"><%= game.stock %> in stock</p>
        </div>
      </div>
    </main>

    <dialog id="updateGameDialog" class="modal">
      <div class="modal-content">
        <h2>Update Game</h2>
        <p class="modal-desc">Update this game's details.</p>
        <form method="post" action="/game/<%= game.id %>" enctype="multipart/form-data">
          <div class="form-group">
            <label for="title">Game Title</label>
            <input type="text" name="title" id="title" required value="<%= game.title %>" />
          </div>
          <div class="form-group">
            <label for="developer">Developer</label>
            <input type="text" name="developer" id="developer" required value="<%= game.developer %>" />
          </div>
          <div class="form-group">
            <label for="price">Price ($)</label>
            <input type="number" step="0.01" name="price" id="price" required value="<%= game.price %>" />
          </div>
          <div class="form-group">
            <label for="stock">Stock Quantity</label>
            <input type="number" name="stock" id="stock" required value="<%= game.stock %>" />
          </div>
          <div class="form-group">
            <label for="image">Cover Image</label>
            <input type="file" name="image" accept="image/*" />
          </div>
          <div class="form-group">
            <label>Genre</label>
            <div class="genre-dialog">
              <% for (const genre of genres) { %>
              <div>
                <input type="checkbox" name="genres[]" id="dialog-<%= genre.genre %>" value="<%= genre.genre %>" <%= game.genres.includes(genre.genre) ? 'checked' : '' %> />
                <label for="dialog-<%= genre.genre %>"><%= genre.genre %></label>
              </div>
              <% } %>
            </div>
          </div>
          <div class="form-actions">
            <button type="submit" class="card-btn">Save Changes</button>
            <button type="button" id="closeUpdateDialog" class="btn-cancel">Cancel</button>
          </div>
        </form>
      </div>
    </dialog>

    <dialog id="deleteGameDialog" class="game-delete-dialog">
      <div>
        <p>Are you sure?</p>
        <p>This action cannot be undone.</p>
        <label for="game-password">Enter Password:</label>
        <input type="password" name="password" id="game-password" />
        <div class="delete-dialog-actions">
          <button class="delete-btn" id="confirmDeleteBtn">Delete</button>
          <button id="closeGameDeleteDialog" class="btn-cancel">Cancel</button>
        </div>
      </div>
    </dialog>

    <script src="/script.js"></script>
  </body>
</html>