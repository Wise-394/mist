<html>
  <head>
    <title>mist</title>
    <link rel="stylesheet" href="/styles.css" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  </head>
  <body>
    <%- include('components/header.ejs') %>
    <main>
      <header>
        <h1>Here Are Games In Stock</h1>
        <button class="add-btn" id="openDialogGame">Add game</button>
      </header>

      <div class="games-grid">
        <% for (const game of games) { %>
        <div class="card">
          <div class="card-img">
            <img src="/image/<%= game.id %>" alt="<%= game.title %>" />
          </div>
          <div class="card-info">
            <h3 class="card-title"><%= game.title %></h3>
            <p class="card-developer"><%= game.developer %></p>
            <div class="card-footer">
              <span class="card-price">$<%= game.price %></span>
              <span class="card-price"><%= game.stock %></span>
              <a href="/game/<%= game.id %>" class="card-btn">View</a>
            </div>
          </div>
        </div>
        <% } %>
      </div>

      <dialog id="gameDialog" class="modal">
        <div class="modal-content">
          <h2>Add Game</h2>
          <p class="modal-desc">Add a new title to the inventory.</p>

          <form method="post" action="/" enctype="multipart/form-data">
            <div class="form-group">
              <label for="title">Game Title</label>
              <input
                type="text"
                name="title"
                id="title"
                required
                placeholder="e.g. Counter-Strike"
              />
            </div>

            <div class="form-group">
              <label for="developer">Developer</label>
              <input
                type="text"
                name="developer"
                id="developer"
                required
                placeholder="e.g. Valve"
              />
            </div>

            <div class="form-group">
              <label for="price">Price ($)</label>
              <input
                type="number"
                step="0.01"
                name="price"
                id="price"
                required
                placeholder="0.00"
              />
            </div>

            <div class="form-group">
              <label for="stock">Stock Quantity</label>
              <input
                type="number"
                name="stock"
                id="stock"
                required
                placeholder="0"
              />
            </div>
            <div class="form-group">
              <label for="image">Cover Image</label>
              <input type="file" name="image" accept="image/*" required />
            </div>
            <div class="form-group">
              <label>Genre</label>
              <div class="genre-dialog">
                <% for (const genre of genres) { %>
                <div>
                  <input
                    type="checkbox"
                    name="genres[]"
                    id="dialog-<%= genre.genre %>"
                    value="<%= genre.genre %>"
                  />
                  <label for="dialog-<%= genre.genre %>"
                    ><%= genre.genre %></label
                  >
                </div>
                <% } %>
              </div>
            </div>
            <div class="form-actions">
              <button type="submit" class="card-btn">Save Game</button>
              <button type="button" id="closeDialogGame" class="btn-cancel">
                Cancel
              </button>
            </div>
          </form>
        </div>
      </dialog>
    </main>

    <script src="/script.js"></script>
  </body>
</html>
