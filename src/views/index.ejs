<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <title>mist</title>
    <link rel="stylesheet" href="/styles.css" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  </head>
  <body>
    <%- include('components/header.ejs') %>

    <main>
      <header class="inventory-header">
        <h1>Here Are Games In Stock</h1>
        <button class="add-btn" id="openDialogGame">Add game</button>
      </header>

      <div class="games-grid">
        <% if (games && games.length > 0) { %>
          <% for (const game of games) { %>
            <div class="card">
              <div class="card-img">
                <img src="/image/<%= game.id %>" alt="<%= game.title %>" />
              </div>
              <div class="card-info">
                <h3 class="card-title"><%= game.title %></h3>
                <p class="card-developer"><%= game.developer %></p>
                <div class="card-footer">
                  <span class="card-price">$<%= game.price %></span>
                  <span class="card-stock">Stock: <%= game.stock %></span>
                  <a href="/game/<%= game.id %>" class="card-btn">View</a>
                </div>
              </div>
            </div>
          <% } %>
        <% } else { %>
          <p>No games found in the inventory.</p>
        <% } %>
      </div>

      <% const hasErrors = locals.errors && errors.length > 0; %>
      <dialog id="gameDialog" class="modal" data-has-errors="<%= hasErrors %>">
        <div class="modal-content">
          <h2>Add Game</h2>
          <p class="modal-desc">Add a new title to the inventory.</p>
          <form method="post" action="/" enctype="multipart/form-data">
            <div class="form-group">
              <label for="title">Game Title</label>
              <input
                type="text"
                name="title"
                id="title"
                value="<%= locals.previousInput?.title || '' %>"
                required
                placeholder="e.g. Counter-Strike"
              />
            </div>

            <div class="form-group">
              <label for="developer">Developer</label>
              <input
                type="text"
                name="developer"
                id="developer"
                value="<%= locals.previousInput?.developer || '' %>"
                required
                placeholder="e.g. Valve"
              />
            </div>

            <div class="form-group">
              <label for="price">Price ($)</label>
              <input
                type="number"
                step="0.01"
                name="price"
                id="price"
                value="<%= locals.previousInput?.price || '' %>"
                required
                placeholder="0.00"
              />
            </div>

            <div class="form-group">
              <label for="stock">Stock Quantity</label>
              <input
                type="number"
                name="stock"
                id="stock"
                value="<%= locals.previousInput?.stock || '' %>"
                required
                placeholder="0"
              />
            </div>

            <div class="form-group">
              <label for="image">Cover Image</label>
              <input type="file" name="image" id="image" accept="image/*" required />
            </div>

            <div class="form-group">
              <label>Genres</label>
              <div class="genre-dialog">
                <% for (const genre of genres) { %>
                  <div class="genre-option">
                    <input
                      type="checkbox"
                      name="genres[]"
                      id="dialog-<%= genre.genre %>"
                      value="<%= genre.genre %>"
                      <% if (locals.previousInput?.genres && (Array.isArray(locals.previousInput.genres) ? locals.previousInput.genres.includes(genre.genre) : locals.previousInput.genres === genre.genre)) { %> checked <% } %>
                    />
                    <label for="dialog-<%= genre.genre %>"><%= genre.genre %></label>
                  </div>
                <% } %>
              </div>
            </div>
            <% if (hasErrors) { %>
            <div class="error-summary">
              <p><strong>Please correct the following:</strong></p>
              <ul>
                <% errors.forEach(err => { %>
                  <li><%= err.msg %></li>
                <% }) %>
              </ul>
            </div>
          <% } %>
            <div class="form-actions">
              <button type="submit" class="card-btn">Save Game</button>
              <button type="button" id="closeDialogGame" class="btn-cancel">
                Cancel
              </button>
            </div>
          </form>
        </div>

      </dialog>
    </main>

    <%- include('components/footer.ejs') %>

    <script src="/script.js"></script>
    <script>
      const gameDialog = document.getElementById('gameDialog');
      if (gameDialog && gameDialog.dataset.hasErrors === 'true') {
        gameDialog.showModal();
      }
    </script>
  </body>
</html>